# IntelliJ IDEA project files
.idea/
*.iml

# Java build artifacts
*.class
*.jar

# Log files
*.log
hs_err_pid*
replay_pid*

# Build output directories
target/
out/
build/

# Temporary files
*.tmp
*.swp
*.bak
*.orig
*.rej

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Visual Studio Code
.vscode/

# macOS system files
.DS_Store

# Windows system files
Thumbs.db
desktop.ini

# Python cache (if scripts are used)
__pycache__/
*.py[cod]

# Compressed files
*.zip
*.tar
*.tar.gz
*.rar

# Machine-local config (never commit)
config.local.properties

# Local archive (decommissioned artifacts kept for reference)
archive_local/

# Tuning and staging output
output/

# Intermediate or large data files (optional)
*.csv
*.json
*.tsv
*.xlsx
*.pdf
